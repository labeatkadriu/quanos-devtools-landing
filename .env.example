# Application
NODE_ENV=production
PORT=3000

# Database
MONGO_URI=mongodb://mongo:27017/devtools

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Initial administrator (created on first boot if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# CORS (comma-separated origins; * for any)
CORS_ORIGIN=*
